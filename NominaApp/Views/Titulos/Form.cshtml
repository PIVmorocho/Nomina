@model NominaApp.Models.Title
@{
    ViewData["Title"] = "Agregar Título";
}
<div class="d-flex align-items-center mb-3 gap-2">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
    <h5 class="mb-0">@ViewData["Title"]</h5>
</div>
<div class="card border-0 shadow-sm" style="max-width:560px">
    <div class="card-body">
        <form asp-action="Agregar" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="alert alert-danger py-2 small"></div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Empleado</label>
                <select asp-for="EmpNo" asp-items="ViewBag.Empleados" class="form-select"><option value="">-- Seleccione --</option></select>
            </div>
            <div class="mb-3">
                <label asp-for="TitleName" class="form-label fw-semibold">Título / Cargo</label>
                <input asp-for="TitleName" class="form-control" placeholder="Ej: Analista de RRHH" />
                <span asp-validation-for="TitleName" class="text-danger small"></span>
            </div>
            <div class="row g-3 mb-3">
                <div class="col"><label asp-for="FromDate" class="form-label fw-semibold"></label><input asp-for="FromDate" class="form-control" type="date" /></div>
                <div class="col"><label asp-for="ToDate" class="form-label fw-semibold"></label><input asp-for="ToDate" class="form-control" type="date" /><div class="form-text">Dejar vacío si es vigente.</div></div>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4"><i class="bi bi-save me-1"></i>Guardar</button>
                <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancelar</a>
            </div>
        </form>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}