@model NominaApp.ViewModels.LoginViewModel
@{
    Layout = "_LoginLayout";
    ViewData["Title"] = "Iniciar Sesión";
}

<div class="login-card">
    <div class="text-center mb-4">
        <i class="bi bi-building-fill fs-1 text-primary"></i>
        <h4 class="mt-2">NominaApp</h4>
        <p class="text-muted small">Sistema de Gestión de Nómina</p>
    </div>

    <form asp-action="Login" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="All" class="alert alert-danger py-2 small" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

        <div class="mb-3">
            <label asp-for="Usuario" class="form-label fw-semibold"></label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-person"></i></span>
                <input asp-for="Usuario" class="form-control" placeholder="usuario" autocomplete="username" />
            </div>
            <span asp-validation-for="Usuario" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Clave" class="form-label fw-semibold"></label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-lock"></i></span>
                <input asp-for="Clave" class="form-control" placeholder="••••••••" autocomplete="current-password" />
            </div>
            <span asp-validation-for="Clave" class="text-danger small"></span>
        </div>

        <div class="mb-3 form-check">
            <input asp-for="Recordar" class="form-check-input" />
            <label asp-for="Recordar" class="form-check-label">Recordarme</label>
        </div>

        <button type="submit" class="btn btn-primary w-100 py-2">
            <i class="bi bi-box-arrow-in-right me-2"></i>Iniciar Sesión
        </button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}