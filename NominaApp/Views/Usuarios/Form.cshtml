@model NominaApp.Models.User
@{
    ViewData["Title"] = "Nuevo Usuario";
}
<div class="d-flex align-items-center mb-3 gap-2">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
    <h5 class="mb-0">@ViewData["Title"]</h5>
</div>
<div class="card border-0 shadow-sm" style="max-width:480px">
    <div class="card-body">
        <form asp-action="Crear" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="alert alert-danger py-2 small"></div>
            <div class="mb-3">
                <label asp-for="Usuario" class="form-label fw-semibold"></label>
                <input asp-for="Usuario" class="form-control" />
                <span asp-validation-for="Usuario" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Empleado</label>
                <select asp-for="EmpNo" asp-items="ViewBag.Empleados" class="form-select"><option value="">-- Seleccione --</option></select>
            </div>
            <div class="mb-3">
                <label asp-for="Rol" class="form-label fw-semibold"></label>
                <select asp-for="Rol" asp-items="ViewBag.Roles" class="form-select"></select>
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Clave inicial</label>
                <input type="password" name="claveTexto" class="form-control" required />
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4"><i class="bi bi-save me-1"></i>Guardar</button>
                <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancelar</a>
            </div>
        </form>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}