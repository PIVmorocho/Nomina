@model NominaApp.Models.Department
@{
    bool esEditar = Model.DeptNo > 0;
    ViewData["Title"] = esEditar ? "Editar Departamento" : "Nuevo Departamento";
}
<div class="d-flex align-items-center mb-3 gap-2">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
    <h5 class="mb-0">@ViewData["Title"]</h5>
</div>
<div class="card border-0 shadow-sm" style="max-width:480px">
    <div class="card-body">
        <form asp-action="@(esEditar ? "Editar" : "Crear")" method="post">
            @Html.AntiForgeryToken()
            @if (esEditar)
            {
                <input type="hidden" asp-for="DeptNo" />
            }
            <div asp-validation-summary="All" class="alert alert-danger py-2 small"></div>
            <div class="mb-3">
                <label asp-for="DeptName" class="form-label fw-semibold"></label>
                <input asp-for="DeptName" class="form-control" />
                <span asp-validation-for="DeptName" class="text-danger small"></span>
            </div>
            @if (esEditar)
            {
                <div class="mb-3 form-check form-switch">
                    <input asp-for="Activo" class="form-check-input" type="checkbox" />
                    <label class="form-check-label fw-semibold">Activo</label>
                </div>
            }
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4"><i class="bi bi-save me-1"></i>Guardar</button>
                <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancelar</a>
            </div>
        </form>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}