<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – NominaApp</title>

    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/NominaApp.styles.css" asp-append-version="true" />

   
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>
        body {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            background: #f5f6fa;
        }

        .sidebar {
            width: 250px;
            min-height: 100vh;
            background: #1e2a3b;
            color: #fff;
            flex-shrink: 0;
        }

            .sidebar a {
                color: #adb5bd;
                text-decoration: none;
                display: block;
                padding: 10px 20px;
                border-radius: 6px;
                margin: 2px 8px;
            }

                .sidebar a:hover,
                .sidebar a.active {
                    background: #2d4a6b;
                    color: #fff;
                }

            .sidebar .nav-section {
                font-size: .72rem;
                letter-spacing: .08em;
                color: #6c757d;
                padding: 14px 20px 4px;
                text-transform: uppercase;
            }

        .main-content {
            flex: 1;
        }

        .topbar {
            background: #fff;
            border-bottom: 1px solid #dee2e6;
            padding: 10px 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .alert-success {
            border-left: 4px solid #198754;
        }

        .alert-danger {
            border-left: 4px solid #dc3545;
        }

        .badge-activo {
            background: #d1fae5;
            color: #065f46;
            border-radius: 4px;
        }

        .badge-inactivo {
            background: #fee2e2;
            color: #991b1b;
            border-radius: 4px;
        }

        .table th {
            background: #f8f9fa;
            font-weight: 600;
            font-size: .87rem;
        }

        .pagination .page-link {
            color: #2d4a6b;
        }

        .pagination .page-item.active .page-link {
            background: #2d4a6b;
            border-color: #2d4a6b;
        }
    </style>
</head>
<body>
    <div class="d-flex">

        <!-- ═══ Sidebar ═══════════════════════════════════════════════════════════ -->
        <nav class="sidebar d-flex flex-column py-3">
            <div class="px-3 mb-3">
                <h5 class="text-white mb-0"><i class="bi bi-building-fill"></i> NominaApp</h5>
                <small class="text-muted">Sistema de Nómina</small>
            </div>

            <div class="nav-section">Principal</div>
            <a asp-controller="Dashboard" asp-action="Index">
                <i class="bi bi-speedometer2 me-2"></i>Dashboard
            </a>

            <div class="nav-section">Gestión</div>
            <a asp-controller="Empleados" asp-action="Index">
                <i class="bi bi-people-fill me-2"></i>Empleados
            </a>
            <a asp-controller="Departamentos" asp-action="Index">
                <i class="bi bi-diagram-3-fill me-2"></i>Departamentos
            </a>
            <a asp-controller="Asignaciones" asp-action="Index">
                <i class="bi bi-person-badge-fill me-2"></i>Asignaciones
            </a>
            <a asp-controller="Gerentes" asp-action="Index">
                <i class="bi bi-person-lines-fill me-2"></i>Gerentes
            </a>
            <a asp-controller="Titulos" asp-action="Index">
                <i class="bi bi-award-fill me-2"></i>Títulos
            </a>
            <a asp-controller="Salarios" asp-action="Index">
                <i class="bi bi-currency-dollar me-2"></i>Salarios
            </a>

            <div class="nav-section">Auditoría y Reportes</div>
            <a asp-controller="Auditoria" asp-action="Index">
                <i class="bi bi-journal-text me-2"></i>Auditoría
            </a>
            <a asp-controller="Reportes" asp-action="Index">
                <i class="bi bi-file-earmark-bar-graph me-2"></i>Reportes
            </a>

            @if (User.IsInRole("Administrador"))
            {
                <div class="nav-section">Administración</div>
                <a asp-controller="Usuarios" asp-action="Index">
                    <i class="bi bi-person-lock me-2"></i>Usuarios
                </a>
            }

            <div class="mt-auto px-3 pt-3 border-top border-secondary">
                <small class="text-muted d-block mb-1">
                    <i class="bi bi-person-circle me-1"></i>@User.Identity?.Name
                </small>
                <small class="text-muted">
                    <i class="bi bi-shield-fill me-1"></i>
                    @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                </small>
            </div>
        </nav>

        <!-- ═══ Contenido Principal ════════════════════════════════════════════════ -->
        <div class="main-content w-100">
            <div class="topbar">
                <h6 class="mb-0 text-muted">@ViewData["Title"]</h6>
                <form asp-controller="Account" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-outline-danger">
                        <i class="bi bi-box-arrow-right me-1"></i>Salir
                    </button>
                </form>
            </div>

            <div class="p-4">
                @if (TempData["Exito"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i>@TempData["Exito"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @RenderBody()
            </div>
        </div>
    </div>

    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>