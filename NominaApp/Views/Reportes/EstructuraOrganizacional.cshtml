@model IEnumerable<NominaApp.ViewModels.ReporteEstructuraItem>
@{
    ViewData["Title"] = "Estructura Organizacional";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0"><i class="bi bi-diagram-3-fill me-2 text-success"></i>Estructura Organizacional</h5>
    <div class="d-flex gap-2">
        <button onclick="window.print()" class="btn btn-outline-secondary btn-sm"><i class="bi bi-printer me-1"></i>Imprimir</button>
        <a asp-action="Index" class="btn btn-outline-primary btn-sm"><i class="bi bi-arrow-left me-1"></i>Volver</a>
    </div>
</div>

@foreach (var depto in Model.GroupBy(r => r.Departamento))
{
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-header bg-white border-0 fw-semibold pt-3">
            <i class="bi bi-building me-2 text-success"></i>@depto.Key
            <span class="text-muted small ms-2">Gerente: @depto.First().Gerente</span>
        </div>
        <div class="card-body p-0">
            <table class="table table-sm align-middle mb-0">
                <thead><tr><th>Empleado</th><th>Título</th><th class="text-end">Salario</th></tr></thead>
                <tbody>
                    @foreach (var emp in depto)
                    {
                        <tr>
                            <td>@emp.Empleado</td>
                            <td>@emp.Titulo</td>
                            <td class="text-end">$@emp.Salario.ToString("N0")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}