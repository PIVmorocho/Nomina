@model NominaApp.ViewModels.FiltroReporteViewModel
@{
    ViewData["Title"] = "Reportes";
}

<h5 class="mb-4"><i class="bi bi-file-earmark-bar-graph me-2 text-primary"></i>Reportes de Nómina</h5>

<div class="row g-4">
    <!-- Nómina Vigente -->
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="rounded-circle bg-primary bg-opacity-10 p-3 d-inline-block mb-3">
                    <i class="bi bi-people-fill fs-3 text-primary"></i>
                </div>
                <h6 class="fw-bold">Nómina Vigente</h6>
                <p class="text-muted small">Listado de empleados con salario vigente por departamento.</p>
                <form method="get" asp-action="NominaVigente">
                    <div class="mb-2">
                        <select name="deptNo" class="form-select form-select-sm">
                            <option value="">Todos los departamentos</option>
                            @foreach (SelectListItem item in (IEnumerable<SelectListItem>)ViewBag.Departamentos)
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        </select>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-sm flex-fill"><i class="bi bi-eye me-1"></i>Ver</button>
                        <button type="submit" name="formato" value="excel" class="btn btn-success btn-sm flex-fill"><i class="bi bi-file-earmark-excel me-1"></i>Excel</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Cambios Salariales -->
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="rounded-circle bg-warning bg-opacity-10 p-3 d-inline-block mb-3">
                    <i class="bi bi-graph-up-arrow fs-3 text-warning"></i>
                </div>
                <h6 class="fw-bold">Cambios Salariales</h6>
                <p class="text-muted small">Historial de modificaciones salariales en un rango de fechas.</p>
                <form method="get" asp-action="CambiosSalariales">
                    <div class="mb-2">
                        <input type="date" name="desde" class="form-control form-control-sm" value="@DateTime.Today.AddMonths(-1).ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="mb-2">
                        <input type="date" name="hasta" class="form-control form-control-sm" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning btn-sm flex-fill text-dark"><i class="bi bi-eye me-1"></i>Ver</button>
                        <button type="submit" name="formato" value="excel" class="btn btn-success btn-sm flex-fill"><i class="bi bi-file-earmark-excel me-1"></i>Excel</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Estructura Organizacional -->
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="rounded-circle bg-success bg-opacity-10 p-3 d-inline-block mb-3">
                    <i class="bi bi-diagram-3-fill fs-3 text-success"></i>
                </div>
                <h6 class="fw-bold">Estructura Organizacional</h6>
                <p class="text-muted small">Vista jerárquica: departamento → gerente → empleados vigentes.</p>
                <form method="get" asp-action="EstructuraOrganizacional">
                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-success btn-sm flex-fill"><i class="bi bi-eye me-1"></i>Ver</button>
                        <button type="submit" name="formato" value="excel" class="btn btn-success btn-sm flex-fill"><i class="bi bi-file-earmark-excel me-1"></i>Excel</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>