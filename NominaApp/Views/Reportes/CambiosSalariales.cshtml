@model IEnumerable<NominaApp.ViewModels.ReporteCambioItem>
@{
    ViewData["Title"] = "Cambios Salariales";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0">
        <i class="bi bi-graph-up-arrow me-2 text-warning"></i>Cambios Salariales
        <small class="text-muted fs-6">@(((DateTime?)ViewBag.Desde)?.ToString("dd/MM/yyyy")) – @(((DateTime?)ViewBag.Hasta)?.ToString("dd/MM/yyyy"))</small>
    </h5>
    <div class="d-flex gap-2">
        <button onclick="window.print()" class="btn btn-outline-secondary btn-sm"><i class="bi bi-printer me-1"></i>Imprimir</button>
        <a asp-action="Index" class="btn btn-outline-primary btn-sm"><i class="bi bi-arrow-left me-1"></i>Volver</a>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead><tr><th>Emp#</th><th>Empleado</th><th>Usuario</th><th>Fecha</th><th class="text-end">Salario</th><th>Detalle</th></tr></thead>
            <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td>@r.EmpNo</td>
                        <td class="fw-semibold">@r.Empleado</td>
                        <td><span class="badge bg-secondary">@r.Usuario</span></td>
                        <td>@r.Fecha.ToString("dd/MM/yyyy")</td>
                        <td class="text-end">$@r.Salario.ToString("N0")</td>
                        <td class="small text-muted">@r.Detalle</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>