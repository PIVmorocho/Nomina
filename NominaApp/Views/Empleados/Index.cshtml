@model IEnumerable<NominaApp.Models.Employee>
@{
    ViewData["Title"] = "Empleados";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0"><i class="bi bi-people-fill me-2 text-primary"></i>Empleados</h5>
    <a asp-action="Crear" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i>Nuevo Empleado
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 pt-3">
        <form method="get" class="row g-2 align-items-center">
            <div class="col-md-5">
                <div class="input-group input-group-sm">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" name="buscar" value="@ViewBag.Buscar"
                           class="form-control" placeholder="Buscar por nombre, CI o correo…" />
                </div>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary btn-sm">Buscar</button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm ms-1">Limpiar</a>
            </div>
        </form>
    </div>

    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>CI</th>
                    <th>Nombre</th>
                    <th>Género</th>
                    <th>Contratación</th>
                    <th>Correo</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var emp in Model)
                {
                    <tr>
                        <td>@emp.EmpNo</td>
                        <td>@emp.Ci</td>
                        <td class="fw-semibold">@emp.FullName</td>
                        <td>@(emp.Gender == "M" ? "Masculino" : "Femenino")</td>
                        <td>@emp.HireDate.ToString("dd/MM/yyyy")</td>
                        <td>@(emp.Correo ?? "-")</td>
                        <td>
                            <span class="badge @(emp.Activo ? "badge-activo" : "badge-inactivo") px-2 py-1">
                                @(emp.Activo ? "Activo" : "Inactivo")
                            </span>
                        </td>
                        <td>
                            <div class="d-flex gap-1">
                                <a asp-action="Ver"
                                   asp-route-id="@emp.EmpNo"
                                   class="btn btn-outline-secondary btn-sm"
                                   title="Ver detalle">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Editar"
                                   asp-route-id="@emp.EmpNo"
                                   class="btn btn-outline-primary btn-sm"
                                   title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                @if (emp.Activo)
                                {
                                    <form asp-action="Desactivar"
                                          asp-route-id="@emp.EmpNo"
                                          method="post"
                                          onsubmit="return confirm('¿Desactivar al empleado @emp.FullName?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="btn btn-outline-danger btn-sm"
                                                title="Desactivar">
                                            <i class="bi bi-person-dash"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">
                            No se encontraron empleados.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if ((int)ViewBag.TotalPags > 1)
    {
        <div class="card-footer bg-white border-0 d-flex justify-content-center">
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    @for (int p = 1; p <= (int)ViewBag.TotalPags; p++)
                    {
                        <li class="page-item @(p == (int)ViewBag.Pagina ? "active" : "")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-pagina="@p"
                               asp-route-buscar="@ViewBag.Buscar">@p</a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>