@model IEnumerable<NominaApp.Models.LogAuditoriaSalarios>
@{
    ViewData["Title"] = "Auditoría de Salarios";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0"><i class="bi bi-journal-text me-2 text-primary"></i>Auditoría de Salarios</h5>
    <a asp-action="ExportarExcel"
       asp-route-empNo="@ViewBag.FiltroEmp" asp-route-usuario="@ViewBag.Usuario"
       asp-route-desde="@ViewBag.Desde" asp-route-hasta="@ViewBag.Hasta"
       class="btn btn-success btn-sm">
        <i class="bi bi-file-earmark-excel me-1"></i>Exportar Excel
    </a>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white border-0 pt-3">
        <form method="get" class="row g-2">
            <div class="col-md-3">
                <input type="text" name="usuario" value="@ViewBag.Usuario" class="form-control form-control-sm" placeholder="Filtrar por usuario…" />
            </div>
            <div class="col-md-2">
                <input type="date" name="desde" value="@(((DateTime?)ViewBag.Desde)?.ToString("yyyy-MM-dd"))" class="form-control form-control-sm" />
            </div>
            <div class="col-md-2">
                <input type="date" name="hasta" value="@(((DateTime?)ViewBag.Hasta)?.ToString("yyyy-MM-dd"))" class="form-control form-control-sm" />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary btn-sm">Filtrar</button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm ms-1">Limpiar</a>
            </div>
        </form>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead><tr><th>#</th><th>Usuario</th><th>Fecha</th><th>Empleado</th><th class="text-end">Salario</th><th>Detalle</th></tr></thead>
            <tbody>
                @foreach (var log in Model)
                {
                    <tr>
                        <td class="text-muted small">@log.Id</td>
                        <td><span class="badge bg-secondary">@log.Usuario</span></td>
                        <td>@log.FechaActualizacion.ToString("dd/MM/yyyy")</td>
                        <td>@(log.Employee?.FullName ?? log.EmpNo.ToString())</td>
                        <td class="text-end fw-semibold">$@log.Salario.ToString("N0")</td>
                        <td class="small text-muted">@log.DetalleCambio</td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">No hay registros de auditoría.</td></tr>
                }
            </tbody>
        </table>
    </div>
    @if ((int)ViewBag.TotalPags > 1)
    {
        <div class="card-footer bg-white border-0 d-flex justify-content-center">
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    @for (int p = 1; p <= (int)ViewBag.TotalPags; p++)
                    {
                        <li class="page-item @(p == (int)ViewBag.Pagina ? "active" : "")">
                            <a class="page-link" asp-action="Index" asp-route-pagina="@p"
                               asp-route-usuario="@ViewBag.Usuario"
                               asp-route-desde="@ViewBag.Desde" asp-route-hasta="@ViewBag.Hasta">@p</a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>